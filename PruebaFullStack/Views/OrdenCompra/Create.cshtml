@model PruebaFullstack.Models.OrdenCompra
@{ ViewData["Title"] = "Nueva Orden de Compra"; Layout = "_Layout"; var proyectos = ViewBag.Proyectos as List<PruebaFullstack.Models.Proyecto>; var rubros = ViewBag.Rubros as List<PruebaFullstack.Models.Rubro>; }
<div class="card-glass p-4">
  <h2 class="fw-bold mb-3">Nueva Orden de Compra</h2>
  <form method="post" asp-action="Create">
    <div class="text-danger mb-2">@Html.ValidationSummary()</div>
    <div class="row g-3">
      <div class="col-md-3">
        <label class="form-label">Fecha</label>
        <input asp-for="Fecha" type="date" class="form-control" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Proveedor</label>
        <input asp-for="Proveedor" class="form-control" placeholder="Proveedor S.A." />
        <span asp-validation-for="Proveedor" class="text-danger"></span>
      </div>
    </div>
    <hr />
    <h5>Detalle</h5>
    <div id="detalles">
      @for (int i = 0; i < Model.Detalles.Count; i++)
      {
        <div class="row g-2 mb-2">
          <div class="col-md-4">
            <select name="Detalles[@i].ProyectoId" class="form-select">
              <option value="">-- Proyecto --</option>
              @foreach (var p in proyectos)
              { <option value="@p.Id">@($"P-{p.Id:D4} - " + p.Nombre)</option> }
            </select>
          </div>
          <div class="col-md-4">
            <select name="Detalles[@i].RubroId" class="form-select">
              <option value="">-- Rubro --</option>
              @foreach (var r in rubros)
              { <option value="@r.Id">@r.Nombre</option> }
            </select>
          </div>
          <div class="col-md-3">
            <input name="Detalles[@i].Monto" class="form-control" placeholder="Monto" />
          </div>
        </div>
      }
    </div>
    <div class="mt-3 d-flex gap-2">
      <button class="btn btn-gradient"><i class="bi bi-check2-circle"></i> Guardar</button>
      <a class="btn btn-outline-light" href="/OrdenCompra">Volver</a>
    </div>
  </form>
</div>
