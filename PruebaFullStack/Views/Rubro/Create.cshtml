@model PruebaFullstack.Models.Rubro
@{ ViewData["Title"] = "Nuevo Rubro"; Layout = "_Layout"; var proyectos = ViewBag.Proyectos as List<PruebaFullstack.Models.Proyecto>; }
<div class="card-glass p-4">
  <h2 class="fw-bold mb-3">Nuevo Rubro</h2>
  <form method="post" asp-action="Create">
    <div class="text-danger mb-2">@Html.ValidationSummary()</div>
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Proyecto</label>
        <select asp-for="ProyectoId" class="form-select">
          <option value="">-- Seleccione --</option>
          @foreach (var p in proyectos)
          {
            <option value="@p.Id">@($"P-{p.Id:D4} - " + p.Nombre)</option>
          }
        </select>
        <span asp-validation-for="ProyectoId" class="text-danger"></span>
      </div>
      <div class="col-md-6">
        <label class="form-label">Nombre del Rubro</label>
        <input asp-for="Nombre" class="form-control" placeholder="Materiales, Mano de obra..." />
        <span asp-validation-for="Nombre" class="text-danger"></span>
      </div>
    </div>
    <div class="mt-3 d-flex gap-2">
      <button class="btn btn-gradient"><i class="bi bi-check2-circle"></i> Guardar</button>
      <a class="btn btn-outline-light" href="/Rubro">Volver</a>
    </div>
  </form>
</div>
